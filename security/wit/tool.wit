package near:agent@0.3.0;

interface host {
    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    log: func(level: log-level, message: string);
    now-millis: func() -> u64;
    workspace-read: func(path: string) -> option<string>;

    record http-response {
        status: u16,
        headers-json: string,
        body: list<u8>,
    }

    http-request: func(
        method: string,
        url: string,
        headers-json: string,
        body: option<list<u8>>,
        timeout-ms: option<u32>,
    ) -> result<http-response, string>;

    tool-invoke: func(alias: string, params-json: string) -> result<string, string>;
    secret-exists: func(name: string) -> bool;
}

interface tool {
    record request {
        params: string,
        context: option<string>,
    }

    record response {
        output: option<string>,
        error: option<string>,
    }

    execute: func(req: request) -> response;
    schema: func() -> string;
    description: func() -> string;
}

world sandboxed-tool {
    import host;
    export tool;
}
